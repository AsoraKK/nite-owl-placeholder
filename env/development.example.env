# Canonical environment variables
APP_ENV=development
APP_BASE_URL=http://dev.niteowlangling.co.za
API_BASE_URL=https://dev-api.niteowlangling.co.za
DATABASE_URL=postgres://dev-test-data-only
ASSETS_BASE_URL=https://dev-assets.niteowlangling.co.za
PAYMENT_PROVIDER=sandbox
PAYMENT_PUBLIC_KEY=replace-with-dev-sandbox-public-key
PAYMENT_SECRET_KEY=replace-with-dev-sandbox-secret-key
PAYMENT_WEBHOOK_SECRET=replace-with-dev-sandbox-webhook-secret
CLOUDFLARE_ACCOUNT_ID=replace-with-dev-account-id
CLOUDFLARE_PROJECT_NAME=nite-owl-placeholder
CLOUDFLARE_API_TOKEN=replace-with-dev-cloudflare-token
SESSION_SECRET=replace-with-dev-session-secret
ADMIN_EMAIL_ALLOWLIST=admin@niteowlangling.co.za
NOINDEX_TEST_ROUTES=true
ENABLE_ADMIN_TEST_ROUTES=true

# Front-end build mirrors for the Vite scaffold
VITE_APP_ENV=development
VITE_APP_BASE_URL=http://dev.niteowlangling.co.za
VITE_API_BASE_URL=https://dev-api.niteowlangling.co.za
VITE_DATABASE_URL=postgres://dev-test-data-only
VITE_ASSETS_BASE_URL=https://dev-assets.niteowlangling.co.za
VITE_PAYMENT_PROVIDER=sandbox
VITE_PAYMENT_PUBLIC_KEY=replace-with-dev-sandbox-public-key
VITE_PAYMENT_SECRET_KEY=replace-with-dev-sandbox-secret-key
VITE_PAYMENT_WEBHOOK_SECRET=replace-with-dev-sandbox-webhook-secret
VITE_CLOUDFLARE_ACCOUNT_ID=replace-with-dev-account-id
VITE_CLOUDFLARE_PROJECT_NAME=nite-owl-placeholder
VITE_CLOUDFLARE_API_TOKEN=replace-with-dev-cloudflare-token
VITE_SESSION_SECRET=replace-with-dev-session-secret
VITE_ADMIN_EMAIL_ALLOWLIST=admin@niteowlangling.co.za
VITE_NOINDEX_TEST_ROUTES=true
VITE_ENABLE_ADMIN_TEST_ROUTES=true
