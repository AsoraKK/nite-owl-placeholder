# Canonical environment variables
APP_ENV=staging
APP_BASE_URL=https://staging.niteowlangling.co.za
API_BASE_URL=https://staging-api.niteowlangling.co.za
DATABASE_URL=postgres://staging-isolated-data-only
ASSETS_BASE_URL=https://staging-assets.niteowlangling.co.za
PAYMENT_PROVIDER=sandbox
PAYMENT_PUBLIC_KEY=replace-with-staging-sandbox-public-key
PAYMENT_SECRET_KEY=replace-with-staging-sandbox-secret-key
PAYMENT_WEBHOOK_SECRET=replace-with-staging-sandbox-webhook-secret
CLOUDFLARE_ACCOUNT_ID=replace-with-staging-account-id
CLOUDFLARE_PROJECT_NAME=nite-owl-placeholder
CLOUDFLARE_API_TOKEN=replace-with-staging-cloudflare-token
SESSION_SECRET=replace-with-staging-session-secret
ADMIN_EMAIL_ALLOWLIST=admin@niteowlangling.co.za
NOINDEX_TEST_ROUTES=true
ENABLE_ADMIN_TEST_ROUTES=true

# Front-end build mirrors for the Vite scaffold
VITE_APP_ENV=staging
VITE_APP_BASE_URL=https://staging.niteowlangling.co.za
VITE_API_BASE_URL=https://staging-api.niteowlangling.co.za
VITE_DATABASE_URL=postgres://staging-isolated-data-only
VITE_ASSETS_BASE_URL=https://staging-assets.niteowlangling.co.za
VITE_PAYMENT_PROVIDER=sandbox
VITE_PAYMENT_PUBLIC_KEY=replace-with-staging-sandbox-public-key
VITE_PAYMENT_SECRET_KEY=replace-with-staging-sandbox-secret-key
VITE_PAYMENT_WEBHOOK_SECRET=replace-with-staging-sandbox-webhook-secret
VITE_CLOUDFLARE_ACCOUNT_ID=replace-with-staging-account-id
VITE_CLOUDFLARE_PROJECT_NAME=nite-owl-placeholder
VITE_CLOUDFLARE_API_TOKEN=replace-with-staging-cloudflare-token
VITE_SESSION_SECRET=replace-with-staging-session-secret
VITE_ADMIN_EMAIL_ALLOWLIST=admin@niteowlangling.co.za
VITE_NOINDEX_TEST_ROUTES=true
VITE_ENABLE_ADMIN_TEST_ROUTES=true
