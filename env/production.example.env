# Canonical environment variables
APP_ENV=production
APP_BASE_URL=https://niteowlangling.co.za
API_BASE_URL=https://api.niteowlangling.co.za
DATABASE_URL=postgres://production-data-only
ASSETS_BASE_URL=https://assets.niteowlangling.co.za
PAYMENT_PROVIDER=live
PAYMENT_PUBLIC_KEY=replace-with-production-public-key
PAYMENT_SECRET_KEY=replace-with-production-secret-key
PAYMENT_WEBHOOK_SECRET=replace-with-production-webhook-secret
CLOUDFLARE_ACCOUNT_ID=replace-with-production-account-id
CLOUDFLARE_PROJECT_NAME=nite-owl-placeholder
CLOUDFLARE_API_TOKEN=replace-with-production-cloudflare-token
SESSION_SECRET=replace-with-production-session-secret
ADMIN_EMAIL_ALLOWLIST=admin@niteowlangling.co.za
NOINDEX_TEST_ROUTES=true
ENABLE_ADMIN_TEST_ROUTES=false

# Front-end build mirrors for the Vite scaffold
VITE_APP_ENV=production
VITE_APP_BASE_URL=https://niteowlangling.co.za
VITE_API_BASE_URL=https://api.niteowlangling.co.za
VITE_DATABASE_URL=postgres://production-data-only
VITE_ASSETS_BASE_URL=https://assets.niteowlangling.co.za
VITE_PAYMENT_PROVIDER=live
VITE_PAYMENT_PUBLIC_KEY=replace-with-production-public-key
VITE_PAYMENT_SECRET_KEY=replace-with-production-secret-key
VITE_PAYMENT_WEBHOOK_SECRET=replace-with-production-webhook-secret
VITE_CLOUDFLARE_ACCOUNT_ID=replace-with-production-account-id
VITE_CLOUDFLARE_PROJECT_NAME=nite-owl-placeholder
VITE_CLOUDFLARE_API_TOKEN=replace-with-production-cloudflare-token
VITE_SESSION_SECRET=replace-with-production-session-secret
VITE_ADMIN_EMAIL_ALLOWLIST=admin@niteowlangling.co.za
VITE_NOINDEX_TEST_ROUTES=true
VITE_ENABLE_ADMIN_TEST_ROUTES=false
